{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/local-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/bash-validator.sh"
          },
          {
            "type": "command",
            "command": ".codex/hooks/file-naming-validator.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/loop-detection.sh"
          }
        ]
      }
    ]
  }
}
